fn calc_area(x:int32, y:int32): int32 {
   x*y;
}

fn main(): int32 {
    var x: int32 = 10;
    var y: int32 = 2;
    
    {
        var x: int32 = 50; 
        y = (x / 2) + !0; 
    }

    var z: int32 = !(-(100 > 10)); 

    var res:int32 = x + y + z + 5;
    res;
    var ress:int32 = calc_area(res, 5);
    ress;
}
