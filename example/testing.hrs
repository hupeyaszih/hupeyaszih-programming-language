fn calc_area(x:int32, y:int32): int32 {
   fn is_greater_than_zero(y:int32):int32{
       y>0;
   }
   {
       fn is_greater_than_zero(y:int32):int32{
           254;
       }

       is_greater_than_zero(x);
   }
   {
       fn is_greater_than_zero(y:int32):int32{
           111;
       }

       is_greater_than_zero(x);
   }

   x * is_greater_than_zero(x) * y * is_greater_than_zero(y);
}

fn main(): int32 {
    var x: int32 = 10;
    var y: int32 = 2;
    
    {
        var x: int32 = 50; 
        y = (x / 2) + !0; 
    }

    var z: int32 = !(-(100 > 10)); 


    var res:int32 = x + y + z + 5;
    res;
    var ress:int32 = calc_area(res, 5);
    ress;
}
