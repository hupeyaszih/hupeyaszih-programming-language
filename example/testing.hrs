// Hupeyaszih Programming Language (.hrs)

fn get_weight(n: int32): int32 {
    1 + (n - ((n / 2) * 2) == 0);
}

fn main(): int32 {
    var total: int32 = 0;
    var x: int32 = 1;

    fn calculate_bonus(val: int32): int32 {
        var bonus: int32 = 0;
        bonus = (val > 4) * 10;
        bonus;
    }


    loop {
        continue(x - ((x / 3) * 3) == 0) {
            x = x + 1;
        }

        total = total + (get_weight(x) + calculate_bonus(x));

        break(x == 5) {
            total;
        }
        x = x + 1;
    }
}
